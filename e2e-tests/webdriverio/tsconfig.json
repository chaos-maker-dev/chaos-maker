{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "@wdio/globals/types", "expect-webdriverio", "@wdio/mocha-framework"]
  },
  "ts-node": {
    "experimentalSpecifierResolution": "node"
  },
  "include": [
    "wdio.conf.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "../fixtures/parity/**/*.ts"
  ]
}
