{
  "name": "chaos-maker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A lightweight toolkit for injecting chaos into web applications",
  "workspaces": [
    "packages/*",
    "e2e-tests/*",
    "docs"
  ],
  "scripts": {
    "lint": "eslint .",
    "build:core": "bun --filter @chaos-maker/core build && node scripts/sync-sw-fixtures.mjs",
    "build:playwright": "bun --filter @chaos-maker/playwright build",
    "build:cypress": "bun --filter @chaos-maker/cypress build",
    "build:webdriverio": "bun --filter @chaos-maker/webdriverio build",
    "build:puppeteer": "bun --filter @chaos-maker/puppeteer build",
    "build:docs": "bun --filter chaos-maker-docs build",
    "build": "bun run build:core && bun run build:playwright && bun run build:cypress && bun run build:webdriverio && bun run build:puppeteer",
    "dev:docs": "bun --filter chaos-maker-docs dev",
    "dev:core": "bun --filter @chaos-maker/core dev",
    "test": "bun --filter @chaos-maker/core test",
    "test:playwright": "bun --filter e2e-tests-playwright test",
    "test:cypress": "bun --filter e2e-tests-cypress test",
    "test:cypress:chrome": "bun --filter e2e-tests-cypress test:chrome",
    "test:cypress:electron": "bun --filter e2e-tests-cypress test:electron",
    "test:cypress:all": "bun run test:cypress:chrome && bun run test:cypress:electron",
    "test:wdio": "bun --filter e2e-tests-webdriverio test",
    "test:wdio:chrome": "bun --filter e2e-tests-webdriverio test:chrome",
    "test:wdio:firefox": "bun --filter e2e-tests-webdriverio test:firefox",
    "test:puppeteer": "bun --filter e2e-tests-puppeteer test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^9.39.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "ws": "^8.20.1"
  },
  "overrides": {
    "minimatch": ">=9.0.7",
    "brace-expansion": ">=5.0.6",
    "picomatch": ">=2.3.2",
    "flatted": ">=3.4.2",
    "yaml": ">=2.8.3",
    "js-yaml": ">=4.1.1",
    "ajv": ">=6.14.0",
    "qs": ">=6.15.2",
    "uuid": ">=11.1.1",
    "diff": ">=8.0.3",
    "rollup": ">=4.59.0",
    "follow-redirects": ">=1.16.0",
    "esbuild": ">=0.27.4",
    "tar-fs": ">=3.1.1",
    "tmp": ">=0.2.4",
    "ws": ">=8.20.1",
    "serialize-javascript": ">=7.0.5",
    "fast-xml-parser": ">=5.7.0",
    "fast-xml-builder": ">=1.1.7",
    "basic-ftp": ">=5.3.1",
    "ip-address": ">=10.1.1",
    "devalue": ">=5.8.1"
  },
  "trustedDependencies": [
    "cypress"
  ],
  "packageManager": "bun@1.3.11",
  "lint-staged": {
    "**/*.ts": "eslint"
  }
}
